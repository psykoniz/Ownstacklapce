[Desktop Entry]
Version=1.0
Type=Application

Name=OwnStack IDE
Comment=Rust-native IDE with embedded AI agents
Categories=Development;IDE;
GenericName=Code Editor
StartupWMClass=ownstack-ide

Icon=io.ownstack.ownstackide
Exec=ownstack-ide %F
Terminal=false
MimeType=text/plain;inode/directory;
Actions=new-window;

[Desktop Action new-window]
Name=New Window
Exec=ownstack-ide --new %F
Icon=io.ownstack.ownstackide
