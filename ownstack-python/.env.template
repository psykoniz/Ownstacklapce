# OwnStack Environment Configuration Template
# Copy this file to .env and fill in the values

# --- LLM PROVIDERS ---
# One of the following is REQUIRED for the agent to function
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OPTIONAL provider configuration
OLLAMA_HOST=http://localhost:11434
OPENROUTER_SITE_URL=https://ownstack.ai
OPENROUTER_APP_NAME=OwnStack IDE

# --- SECURITY ---
# REQUIRED: Generate a strong secret key (at least 32 chars) for JWT
OWNSTACK_SECRET_KEY=os-dev-secret-change-me

# --- DOCKER ---
# Ensure Docker Desktop is running. No specific ENV needed if using default socket.
# The backend will check availability via 'docker version'

# --- TESTING & DEBUG ---
# Set to 1 to enable testing mode (bypasses some checks)
OWNSTACK_TESTING=0
LOG_LEVEL=INFO
